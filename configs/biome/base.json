{
	"$schema": "https://biomejs.dev/schemas/latest/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!**/node_modules/**",
			"!**/out/**",
			"!**/dist/**",
			"!**/.next/**",
			"!**/*.tgz",
			"!**/coverage/**",
			"!**/*.lcov",
			"!**/logs/**",
			"!**/*.log",
			"!**/report.*.*.*.*.json",
			"!**/.env",
			"!**/.env.development.local",
			"!**/.env.test.local",
			"!**/.env.production.local",
			"!**/.env.local",
			"!**/.eslintcache",
			"!**/.cache/**",
			"!**/.turbo/**",
			"!**/*.tsbuildinfo",
			"!**/.idea/**",
			"!**/.DS_Store",
			"!**/TEMP_LOOKUP/**"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "space",
		"indentWidth": 2,
		"lineWidth": 100,
		"formatWithErrors": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "error",
				"useExhaustiveDependencies": "off"
			},
			"style": {
				"useConst": "error",
				"useTemplate": "error"
			},
			"suspicious": {
				"noDebugger": "error",
				"noExplicitAny": "error",
				"noArrayIndexKey": "off"
			},
			"performance": {
				"noDelete": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "es5",
			"semicolons": "asNeeded"
		}
	},
	"json": {
		"formatter": {
			"trailingCommas": "none"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
