{
  "name": "be",
  "version": "1.0.0",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "bun run --watch src/index.ts",
    "db:studio": "drizzle-kit studio",
    "build": "echo 'Build skipped - running from source in production'",
    "build:bundle": "bun build --minify-whitespace --minify-syntax --target bun --outdir dist ./src/index.ts",
    "build:compile": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server ./src/index.ts"
  },
  "dependencies": {
    "@elysiajs/bearer": "latest",
    "@elysiajs/cors": "latest",
    "@elysiajs/html": "latest",
    "@elysiajs/jwt": "latest",
    "@elysiajs/opentelemetry": "latest",
    "@elysiajs/static": "latest",
    "@monorepo/db-entities": "workspace:*",
    "@monorepo/drizzle-manager": "workspace:*",
    "@monorepo/file-manager": "workspace:*",
    "@monorepo/generics": "workspace:*",
    "@monorepo/redis-manager": "workspace:*",
    "argon2": "latest",
    "dotenv": "latest",
    "drizzle-orm": "0.44.7",
    "elysia": "latest",
    "nanoid": "latest",
    "pg": "latest",
    "jsonwebtoken": "latest",
    "postgres": "latest",
    "bcryptjs": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@monorepo/configs": "workspace:*",
    "@types/bcryptjs": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/pg": "latest",
    "bun-types": "latest",
    "cross-env": "latest",
    "drizzle-kit": "^0.31.5"
  },
  "module": "src/index.js"
}