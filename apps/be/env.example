#AUTH V2 (JWT + Session Store)
JWT_SECRET=
JWT_EXPIRES_IN=30m
JWT_ISSUER=nucleus-auth
JWT_AUDIENCE=
JWT_ALGORITHM=HS256
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d
JWT_REFRESH_ISSUER=nucleus-auth
JWT_REFRESH_AUDIENCE=
