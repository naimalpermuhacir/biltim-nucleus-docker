{
	"$schema": "https://turbo.build/schema.json",
	"globalEnv": ["NODE_ENV", "AUTH_API_URL", "NEXT_TELEMETRY_DISABLED"],
	"globalDependencies": ["package.json", "bun.lock", "tsconfig.json"],
	"tasks": {
		"//#format-and-lint": {
			"cache": true,
			"outputs": []
		},
		"//#format-and-lint:fix": {
			"cache": false,
			"outputs": []
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**"],
			"env": ["NODE_ENV", "AUTH_API_URL", "NEXT_TELEMETRY_DISABLED"],
			"cache": true
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"start": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"cache": true,
			"outputs": []
		},
		"test": {
			"cache": true,
			"outputs": ["coverage/**"]
		}
	},
	"remoteCache": {
		"enabled": false
	}
}
